generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id              String         @id
  name            String         @db.Text
  email           String         @unique
  emailVerified   Boolean        @default(false)
  image           String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  username        String?        @db.Text
  displayUsername String?        @db.Text
  role            String?        @db.Text
  banned          Boolean?       @default(false)
  banReason       String?        @db.Text
  banExpires      DateTime?
  departmentId    String?
  divisiId        String?
  accounts        Account[]
  assetHistory    AssetHistory[]
  loansApproved   AssetLoan[]    @relation("approvedBy")
  loansBorrowed   AssetLoan[]    @relation("borrower")
  loansRequested  AssetLoan[]    @relation("requestedBy")
  auditLogs       AuditLog[]
  invitations     Invitation[]
  members         Member[]
  sessions        Session[]
  teammember      teamMember[]
  department      department?    @relation(fields: [departmentId], references: [id_department])
  divisi          divisi?        @relation(fields: [divisiId], references: [id_divisi])

  @@index([departmentId])
  @@index([divisiId])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?  @db.Text
  userAgent            String?  @db.Text
  userId               String
  impersonatedBy       String?  @db.Text
  activeOrganizationId String?  @db.Text
  activeTeamId         String?  @db.Text
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String    @db.Text
  providerId            String    @db.Text
  userId                String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?   @db.Text
  password              String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String   @db.Text
  value      String   @db.Text
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier(length: 191)])
  @@map("verification")
}

model Organization {
  id               String             @id
  name             String             @db.Text
  slug             String             @unique
  logo             String?            @db.Text
  createdAt        DateTime
  metadata         String?            @db.Text
  department       department[]
  divisi           divisi[]
  invitations      Invitation[]
  members          Member[]
  organizationrole organizationRole[]
  teams            Team[]
  items            Item[]
  assets           Asset[]
  categories       Category[]
  locations        Location[]
  stocks           Stock[]
  assetLoans       AssetLoan[]
  assetTransfers   AssetTransfer[]
  auditLogs        AuditLog[]
  assetHistory     AssetHistory[]

  @@map("organization")
}

model Team {
  id             String         @id
  name           String         @db.Text
  organizationId String
  createdAt      DateTime
  updatedAt      DateTime?      @updatedAt
  div_team_rel   div_team_rel[]
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teammember     teamMember[]

  @@index([organizationId])
  @@map("team")
}

model Member {
  id             String       @id
  organizationId String
  userId         String
  role           String       @db.Text
  createdAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  email          String       @db.Text
  role           String?      @db.Text
  teamId         String?      @db.Text
  status         String       @db.Text
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email(length: 191)])
  @@index([inviterId], map: "invitation_inviterId_fkey")
  @@map("invitation")
}

model organizationRole {
  id             String       @id
  organizationId String
  role           String       @db.Text
  permission     String       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organizationRole_organizationId_fkey")

  @@index([organizationId], map: "organizationRole_organizationId_idx")
  @@index([role(length: 191)], map: "organizationRole_role_idx")
  @@map("organizationrole")
}

model teamMember {
  id        String    @id
  teamId    String
  userId    String
  createdAt DateTime?
  team      Team      @relation(fields: [teamId], references: [id], onDelete: Cascade, map: "teamMember_teamId_fkey")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "teamMember_userId_fkey")

  @@index([teamId], map: "teamMember_teamId_idx")
  @@index([userId], map: "teamMember_userId_idx")
  @@map("teammember")
}

model Item {
  id             String       @id @default(uuid())
  code           String
  name           String
  categoryId     String?
  description    String?
  assetType      AssetType
  createdAt      DateTime     @default(now())
  createdBy      String?
  updatedAt      DateTime?
  updatedBy      String?
  organizationId String
  assets         Asset[]
  category       Category?    @relation(fields: [categoryId, organizationId], references: [id, organizationId])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stocks         Stock[]

  @@unique([code, organizationId])
  @@unique([id, organizationId])
  @@index([categoryId, organizationId])
  @@index([organizationId])
  @@map("items")
}

model Asset {
  id             String          @id @default(uuid())
  itemId         String
  purchaseDate   DateTime?
  purchasePrice  Float?
  condition      String?
  warrantyExpire DateTime?
  locationId     String?
  departmentId   String?
  assignedUserId String?
  serialNumber   String?
  brand          String?         @db.Char(100)
  model          String?         @db.Char(100)
  partNumber     String?         @db.Char(100)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime?
  barcode        String?         @db.Char(100)
  garansi_exp    DateTime?
  status         String          @default("ACTIVE") @db.VarChar(50)
  vendorName     String?         @db.Char(100)
  history        AssetHistory[]
  loans          AssetLoan[]
  item           Item            @relation(fields: [itemId, organizationId], references: [id, organizationId])
  location       Location?       @relation(fields: [locationId, organizationId], references: [id, organizationId])
  department     department?     @relation(fields: [departmentId], references: [id_department])
  transfers      AssetTransfer[] @relation("AssetTransfers")
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([id, organizationId])
  @@unique([barcode, organizationId])
  @@unique([serialNumber, organizationId])
  @@index([itemId, organizationId])
  @@index([organizationId])
  @@map("assets")
}

model Stock {
  id             String             @id @default(uuid())
  itemId         String
  quantity       Int
  locationId     String?
  departmentId   String?
  updatedAt      DateTime           @updatedAt
  transactions   StockTransaction[]
  item           Item               @relation(fields: [itemId, organizationId], references: [id, organizationId])
  location       Location?          @relation(fields: [locationId, organizationId], references: [id, organizationId])
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([itemId, locationId])
  @@index([locationId, organizationId])
  @@index([organizationId])
  @@map("stocks")
}

model StockTransaction {
  id        String          @id @default(uuid())
  stockId   String
  type      TransactionType
  quantity  Int
  reference String?
  notes     String?
  createdAt DateTime        @default(now())
  stock     Stock           @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@index([stockId], map: "stock_transactions_stockId_fkey")
  @@map("stock_transactions")
}

model Category {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  items          Item[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([id, organizationId])
  @@index([organizationId])
  @@map("categories")
}

model Location {
  id             String          @id @default(uuid())
  name           String
  stocks         Stock[]
  transfersFrom  AssetTransfer[] @relation("FromLocation")
  transfersTo    AssetTransfer[] @relation("ToLocation")
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assets         Asset[]

  @@unique([id, organizationId])
  @@index([organizationId])
  @@map("locations")
}

model department {
  id_department   String          @id
  organization_id String
  kode_department String          @db.Text
  nama_department String          @db.Text
  id_hod          String          @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  deleted_at      DateTime?
  organization    Organization    @relation(fields: [organization_id], references: [id], onDelete: Cascade, map: "Department_organization_id_fkey")
  divisi          divisi[]
  users           User[]
  assets          Asset[]
  transfersFrom   AssetTransfer[] @relation("FromDept")
  transfersTo     AssetTransfer[] @relation("ToDept")

  @@unique([organization_id, kode_department(length: 191)], map: "department_org_kode_unique_custom_v9")
  @@index([deleted_at], map: "department_deleted_at_idx_custom_v9")
  @@index([organization_id], map: "department_organization_id_idx_custom_v9")
}

model divisi {
  id_divisi       String         @id
  department_id   String
  organization_id String
  nama_divisi     String         @db.Text
  ext_tlp         String         @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime
  deleted_at      DateTime?
  div_team_rel    div_team_rel[]
  department      department     @relation(fields: [department_id], references: [id_department], map: "Divisi_department_id_fkey")
  organization    Organization   @relation(fields: [organization_id], references: [id], onDelete: Cascade, map: "Divisi_organization_id_fkey")
  users           User[]

  @@index([department_id], map: "Divisi_department_id_fkey")
  @@index([deleted_at], map: "divisi_deleted_at_idx_custom_v9")
  @@index([organization_id, department_id], map: "divisi_org_dept_idx_custom_v9")
}

model AssetHistory {
  id             String        @id @default(uuid())
  assetId        String?
  asset_info     String?       @db.Text
  userId         String
  action         String        @db.VarChar(50)
  field          String?       @db.VarChar(50)
  oldValue       String?       @db.Text
  newValue       String?       @db.Text
  createdAt      DateTime      @default(now())
  asset          Asset?        @relation(fields: [assetId, organizationId], references: [id, organizationId])
  user           User          @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([assetId, organizationId])
  @@index([userId], map: "asset_history_userId_fkey")
  @@index([organizationId])
  @@map("asset_history")
}

model AuditLog {
  id             String        @id @default(uuid())
  userId         String?
  action         String        @db.VarChar(100)
  entityType     String        @db.VarChar(100)
  entityId       String?       @db.VarChar(100)
  entityInfo     String?       @db.Text
  details        String?       @db.LongText
  ipAddress      String?       @db.VarChar(50)
  userAgent      String?       @db.Text
  createdAt      DateTime      @default(now())
  user           User?         @relation(fields: [userId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@map("audit_logs")
}

model AssetLoan {
  id                String       @id @default(uuid())
  assetId           String
  borrowerId        String
  requestedById     String
  approvedById      String?
  loanDate          DateTime?
  dueDate           DateTime?
  returnDate        DateTime?
  conditionOnLoan   String?      @db.Text
  conditionOnReturn String?      @db.Text
  status            String       @default("PENDING") @db.VarChar(50)
  notes             String?      @db.Text
  rejectionReason   String?      @db.Text
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  approvedBy        User?        @relation("approvedBy", fields: [approvedById], references: [id])
  asset             Asset        @relation(fields: [assetId, organizationId], references: [id, organizationId], onDelete: Cascade)
  borrower          User         @relation("borrower", fields: [borrowerId], references: [id])
  requestedBy       User         @relation("requestedBy", fields: [requestedById], references: [id])
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([assetId, organizationId])
  @@index([borrowerId])
  @@index([requestedById])
  @@index([approvedById])
  @@index([organizationId])
  @@map("asset_loans")
}

model AssetTransfer {
  id             String       @id @default(uuid())
  assetId        String
  fromLocationId String?
  toLocationId   String?
  fromDeptId     String?
  toDeptId       String?
  fromDivId      String?
  toDivId        String?
  reason         String?      @db.Text
  transferBy     String?
  transferDate   DateTime     @default(now())
  fromLocation   Location?    @relation("FromLocation", fields: [fromLocationId, organizationId], references: [id, organizationId])
  toLocation     Location?    @relation("ToLocation", fields: [toLocationId, organizationId], references: [id, organizationId])
  fromDept       department?  @relation("FromDept", fields: [fromDeptId], references: [id_department])
  toDept         department?  @relation("ToDept", fields: [toDeptId], references: [id_department])
  asset          Asset        @relation("AssetTransfers", fields: [assetId, organizationId], references: [id, organizationId], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([assetId, organizationId])
  @@index([fromLocationId, organizationId])
  @@index([toLocationId, organizationId])
  @@index([organizationId])
  @@map("asset_transfers")
}

model div_team_rel {
  A      String
  B      String
  team   Team   @relation(fields: [A], references: [id], onDelete: Cascade)
  divisi divisi @relation(fields: [B], references: [id_divisi], onDelete: Cascade)

  @@unique([A, B], map: "_div_team_rel_AB_unique")
  @@index([B], map: "_div_team_rel_B_index")
  @@map("_div_team_rel")
}

enum TransactionType {
  IN
  OUT
  ADJUSTMENT
}

enum AssetType {
  FIXED
  SUPPLY
}
